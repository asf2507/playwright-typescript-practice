{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "lib": ["es2020", "dom"],
    "moduleResolution": "node16",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "rootDir": "./tests"
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules"]
}